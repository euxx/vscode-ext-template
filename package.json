{
  "name": "extension-name",
  "displayName": "Extension Display Name",
  "description": "Short description.",
  "version": "0.1.0",
  "publisher": "PUBLISHER",
  "license": "MIT",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [],
  "keywords": [],
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run ci",
    "ci": "npm run test && npm run lint && npm run format:check",
    "test": "vitest run",
    "lint": "oxlint src/ tests/",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "package": "npx @vscode/vsce package --no-dependencies",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "latest",
    "lint-staged": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "prettier": "latest",
    "vitest": "latest"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PUBLISHER/extension-name"
  }
}
